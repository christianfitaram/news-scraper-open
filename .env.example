# Core app
APP_NAME=news-crawler-ai
LOG_LEVEL=INFO
STATE_FILE=crawler_state.json
HF_HOME=./models/transformers
NEWS_FETCH_TIMEOUT=20
FORCE_CPU=0

# Feature flags
ENABLE_WEBHOOKS=1
ENABLE_GENAI=0
ENABLE_OLLAMA=1
ENABLE_SELENIUM_SCRAPERS=1
ENABLE_NEWSAPI_SCRAPER=0

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGODB_DB=agents
MONGO_ARTICLES_COLLECTION=articles
MONGO_LINK_POOL_COLLECTION=link_pool
MONGO_METADATA_COLLECTION=metadata
MONGO_LOGS_COLLECTION=pipeline_logs

# GenAI / Gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
GENAI_MODEL=gemini-2.0-flash
GENAI_TEMPERATURE=0.0
GENAI_TOP_P=1.0
GENAI_MAX_CHUNK_CHARS=12000

# Ollama
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=news-crawler-ollama
OLLAMA_TIMEOUT=60
OLLAMA_TEMPERATURE=0
OLLAMA_MAX_CHUNK_CHARS=12000

# Webhooks
WEBHOOK_URL=
WEBHOOK_URL_THREAD_EVENTS=
WEBHOOK_SIGNATURE=
WEBHOOK_TIMEOUT=60
WEBHOOK_MAX_RETRIES=3

# NewsAPI
NEWSAPI_KEY=

# Selenium / Chrome
CHROME_BIN=
CHROME_BINARY=
CHROMEDRIVER_PATH=
CHROMEDRIVER_VERSION=
CHROME_USER_DATA_DIR=/tmp/chrome-user-data
